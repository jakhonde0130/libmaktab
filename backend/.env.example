NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Supabase project (get from Supabase dashboard > Project Settings > API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Service role key - server-side only, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300

# Notifications (optional, wired later)
TELEGRAM_BOT_TOKEN=
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
